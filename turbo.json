{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [".next/**", "!.next/cache/**"],
      "env": ["DATABASE_URL", "PAYLOAD_DATABASE_URL", "POSTGRES_URL", "POSTGRES_PRISMA_URL", "NODE_ENV", "resend_api_key", "REDIS_URL", "ADMIN_EMAIL", "SENDER_EMAIL", "TEST_RECIPIENT_EMAIL", "PAYLOAD_SECRET", "NEXT_PUBLIC_SERVER_URL", "NEXT_PUBLIC_WEB_URL", "NEXT_PUBLIC_ALLOW_INDEXING", "BLOB_READ_WRITE_TOKEN", "API_KEY_PEXELS", "NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY", "CLERK_SECRET_KEY", "NEXT_PUBLIC_OPS_URL", "NEXT_PUBLIC_APP_URL", "NEXT_PUBLIC_API_URL", "NEXT_PUBLIC_SENTRY_DSN", "SENTRY_DSN", "SENTRY_ORG", "SENTRY_PROJECT", "SENTRY_AUTH_TOKEN", "SENTRY_ENVIRONMENT", "SENTRY_RELEASE", "CI", "OPS_CORS_ORIGINS", "API_CORS_ORIGINS", "EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY", "EXPO_PUBLIC_OPS_URL", "EXPO_PUBLIC_API_URL"]
    },
    "lint": {
      "dependsOn": ["^lint"],
      "env": ["DATABASE_URL", "PAYLOAD_DATABASE_URL", "POSTGRES_URL", "POSTGRES_PRISMA_URL", "NODE_ENV", "resend_api_key", "REDIS_URL", "ADMIN_EMAIL", "SENDER_EMAIL", "TEST_RECIPIENT_EMAIL", "PAYLOAD_SECRET", "NEXT_PUBLIC_SERVER_URL", "NEXT_PUBLIC_WEB_URL", "NEXT_PUBLIC_ALLOW_INDEXING", "BLOB_READ_WRITE_TOKEN", "API_KEY_PEXELS", "NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY", "CLERK_SECRET_KEY", "NEXT_PUBLIC_OPS_URL", "NEXT_PUBLIC_APP_URL", "NEXT_PUBLIC_API_URL", "NEXT_PUBLIC_SENTRY_DSN", "SENTRY_DSN", "SENTRY_ORG", "SENTRY_PROJECT", "SENTRY_AUTH_TOKEN", "SENTRY_ENVIRONMENT", "SENTRY_RELEASE", "CI", "OPS_CORS_ORIGINS", "API_CORS_ORIGINS", "EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY", "EXPO_PUBLIC_OPS_URL", "EXPO_PUBLIC_API_URL"]
    },
    "format": {
      "dependsOn": ["^format"]
    },
    "typecheck": {
      "dependsOn": ["^typecheck"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}
