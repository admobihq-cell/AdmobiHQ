# Copy to `apps/web/.env.local` for local development (required for npm run db:push, etc.).
# Infisical: secrets in the dashboard are NOT loaded automatically — either run
#   infisical run -- npm run db:push -w web
# or paste values into apps/web/.env.local from Infisical.
# Never commit real secrets.

# PostgreSQL connection string (Neon → Connection details → pooled URL)
# Prisma (leads, drivers, fleet_partners) uses this.
DATABASE_URL=

# Optional: separate Neon database for Payload CMS only (safest for production).
# If unset, Payload uses DATABASE_URL with schema migrations only (push disabled).
# PAYLOAD_DATABASE_URL=

# Payload CMS — random 32+ character secret (openssl rand -hex 32)
PAYLOAD_SECRET=

# Public site URL for Payload admin links (https://admobihq.com in production)
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# Business API origin (apps/api → api.admobihq.com). Used by marketing forms at build time.
NEXT_PUBLIC_API_URL=http://localhost:3003

# Ops console links to marketing site / CMS (defaults to NEXT_PUBLIC_SERVER_URL)
# NEXT_PUBLIC_WEB_URL=http://localhost:3000

# Staging only — set to false on staging.admobihq.com to disable sitemap + add noindex
# NEXT_PUBLIC_ALLOW_INDEXING=true

# Vercel Blob — media uploads in Payload (Infisical / Vercel Storage)
BLOB_READ_WRITE_TOKEN=

# Pexels — stock image search in Payload admin (https://www.pexels.com/api/)
API_KEY_PEXELS=

# Resend API key for transactional email (get from resend.com/api-keys)
resend_api_key=

# Email address used as the sender (must use verified domain admobihq.com)
SENDER_EMAIL=Admobi <noreply@admobihq.com>

# Comma-separated inboxes for lead/driver admin alerts (optional override)
ADMIN_EMAIL=admobihq@gmail.com,victor@admobihq.com,japheth@admobihq.com

# Only used in development to redirect all emails to a test inbox
TEST_RECIPIENT_EMAIL=

# Redis connection string for Bull email queue (get from Upstash or Railway)
REDIS_URL=

# --- Sentry (admobi-media / admobi-hq) — one project, filter by `app` tag ---
NEXT_PUBLIC_SENTRY_DSN=https://31b3bd4f4e11809c71541c8dcb24a3f4@o4511701700182016.ingest.de.sentry.io/4511701707194448
SENTRY_DSN=https://31b3bd4f4e11809c71541c8dcb24a3f4@o4511701700182016.ingest.de.sentry.io/4511701707194448
SENTRY_ORG=admobi-media
SENTRY_PROJECT=admobi-hq
# SENTRY_AUTH_TOKEN=   # build-time only — create at sentry.io → Settings → Auth Tokens
# SENTRY_ENVIRONMENT=development

# --- Business API (apps/api → api.admobihq.com) — store in Infisical dev + prod ---
# NEXT_PUBLIC_API_URL=http://localhost:3003
# API_CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3002
# resend_api_key=   (moved from web — form emails)
# REDIS_URL=

# --- Ops console (apps/ops → ops.admobihq.com) — store in Infisical dev + prod ---
# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
# CLERK_SECRET_KEY=
# NEXT_PUBLIC_OPS_URL=http://localhost:3001
# NEXT_PUBLIC_WEB_URL=http://localhost:3000
# NEXT_PUBLIC_API_URL=http://localhost:3003
