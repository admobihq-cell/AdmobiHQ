# Copy to `.env.local` (apps/web) or root `.env` for local development.
# Never commit real secrets.

# PostgreSQL connection string (get from Supabase/Railway/Neon dashboard)
DATABASE_URL=

# Resend API key for transactional email (get from resend.com/api-keys)
RESEND_API_KEY=

# Email address used as the sender for all outgoing emails
SENDER_EMAIL=

# Email address that receives lead and driver notification emails
ADMIN_EMAIL=

# Only used in development to redirect all emails to a test inbox
TEST_RECIPIENT_EMAIL=

# Redis connection string for Bull email queue (get from Upstash or Railway)
REDIS_URL=
