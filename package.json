{
  "name": "Admobi",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "dev": "node scripts/dev-with-env.mjs",
    "dev:all": "node scripts/dev-with-env.mjs --mobile",
    "dev:stack:mobile": "node scripts/dev-with-env.mjs --mobile-stack",
    "dev:stack:mobile:ops": "node scripts/dev-with-env.mjs --mobile-stack --ops-only",
    "dev:stack:mobile:customer": "node scripts/dev-with-env.mjs --mobile-stack --customer-only",
    "dev:stack:mobile:skip-pull": "node scripts/dev-with-env.mjs --mobile-stack --skip-pull",
    "dev:mobile": "npm run dev:clear -w ops-mobile",
    "dev:mobile:customer": "npm run dev:clear -w customer-mobile",
    "dev:skip-pull": "node scripts/dev-with-env.mjs --skip-pull",
    "dev:staging": "node scripts/dev-with-env.mjs --staging",
    "dev:turbo": "turbo dev --filter=web --filter=api --filter=ops --filter=customer-web",
    "lint": "turbo lint",
    "format": "turbo format",
    "typecheck": "turbo typecheck",
    "env:pull": "npm run env:pull -w web && npm run env:pull -w ops && npm run env:pull -w customer-web && npm run env:pull -w api && npm run env:pull -w ops-mobile && npm run env:pull -w customer-mobile",
    "env:pull:mobile-stack": "npm run env:pull -w api && npm run env:pull -w ops-mobile && npm run env:pull -w customer-mobile",
    "env:pull:staging": "npm run env:pull:staging -w web && npm run env:pull:staging -w ops && npm run env:pull:staging -w customer-web && npm run env:pull:staging -w api && npm run env:pull:staging -w ops-mobile && npm run env:pull:staging -w customer-mobile",
    "env:pull:mobile-stack:staging": "npm run env:pull:staging -w api && npm run env:pull:staging -w ops-mobile && npm run env:pull:staging -w customer-mobile",
    "mobile:assets:sync": "node scripts/sync-mobile-brand-assets.mjs",
    "mobile:prebuild": "npm run prebuild:android -w ops-mobile && npm run prebuild:android -w customer-mobile",
    "mobile:apk:local": "node scripts/build-apk-local.mjs all",
    "mobile:apk:local:ops": "node scripts/build-apk-local.mjs ops-mobile",
    "mobile:apk:local:customer": "node scripts/build-apk-local.mjs customer-mobile",
    "mobile:apk:eas:ops": "npm run build:android:preview -w ops-mobile",
    "mobile:apk:eas:customer": "npm run build:android:preview -w customer-mobile",
    "mobile:apk:eas": "npm run mobile:apk:eas:ops && npm run mobile:apk:eas:customer",
    "postinstall": "patch-package"
  },
  "devDependencies": {
    "@workspace/eslint-config": "*",
    "@workspace/typescript-config": "*",
    "patch-package": "^8.0.1",
    "prettier": "^3.9.6",
    "prettier-plugin-tailwindcss": "^0.8.1",
    "turbo": "^2.10.6",
    "typescript": "5.9.3"
  },
  "packageManager": "npm@11.12.1",
  "overrides": {
    "@sentry/nextjs": "^10.64.0",
    "zod": "3.25.76",
    "web": {
      "react": "19.2.4",
      "react-dom": "19.2.4"
    },
    "ops": {
      "react": "19.2.4",
      "react-dom": "19.2.4"
    },
    "api": {
      "react": "19.2.4",
      "react-dom": "19.2.4"
    },
    "customer-web": {
      "react": "19.2.4",
      "react-dom": "19.2.4"
    },
    "ops-mobile": {
      "react": "19.1.0",
      "react-dom": "19.1.0"
    },
    "customer-mobile": {
      "react": "19.1.0",
      "react-dom": "19.1.0"
    }
  },
  "engines": {
    "node": ">=20"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "dependencies": {
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "expo": "~54.0.35",
    "expo-router": "~6.0.23",
    "metro": "^0.87.0",
    "metro-config": "^0.87.0",
    "metro-runtime": "^0.87.0"
  }
}
