{
  "name": "app",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "dotenv -e .env.local -e ../web/.env.local -- next dev --port 3002 --webpack",
    "build": "next build --webpack",
    "start": "next start --port 3002",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "env:check": "dotenv -e .env.local -- tsx scripts/check-env.ts",
    "env:pull": "infisical export --env=dev --format=dotenv --output-file=.env.local",
    "env:pull:staging": "infisical export --env=staging --format=dotenv --output-file=.env.local"
  },
  "dependencies": {
    "@sentry/nextjs": "^10.64.0",
    "@vercel/analytics": "^2.0.1",
    "@workspace/sentry-config": "^0.0.0",
    "@workspace/ui": "*",
    "dotenv": "^16.6.1",
    "lucide-react": "^1.24.0",
    "next": "^16.2.10",
    "react": "19.2.7",
    "react-dom": "19.2.7"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.2",
    "@types/node": "^25.1.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@workspace/eslint-config": "*",
    "@workspace/typescript-config": "*",
    "dotenv-cli": "^8.0.0",
    "eslint": "^9.39.2",
    "tsx": "^4.23.0",
    "typescript": "^5.9.3"
  }
}
