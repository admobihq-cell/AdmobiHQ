# Pulled from Infisical — do not commit real values.
# From repo root: npm run env:pull -w mobile
# Staging: npm run env:pull:staging -w mobile
# Requires: infisical login && infisical init (see docs/DEV-SETUP.md)
#
# env:pull maps Infisical NEXT_PUBLIC_* keys to Expo EXPO_PUBLIC_* automatically.
# On a physical device, set OPS URL to your machine's LAN IP (not localhost).

EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=
EXPO_PUBLIC_OPS_URL=http://localhost:3001
