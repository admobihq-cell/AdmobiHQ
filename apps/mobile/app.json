{
  "expo": {
    "name": "Admobi Ops",
    "slug": "admobihq-ops",
    "version": "0.0.1",
    "orientation": "portrait",
    "runtimeVersion": "0.0.1",
    "icon": "./assets/images/icon.png",
    "scheme": "admobihq",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.admobihq.ops"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#FAF9F7",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "package": "com.admobihq.ops",
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-dev-client",
      "expo-secure-store",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "resizeMode": "contain",
          "backgroundColor": "#000000",
          "imageWidth": 200,
          "ios": {
            "backgroundColor": "#000000",
            "image": "./assets/images/splash-icon.png",
            "resizeMode": "contain"
          },
          "android": {
            "backgroundColor": "#000000",
            "image": "./assets/images/splash-icon.png",
            "resizeMode": "contain",
            "imageWidth": 200
          }
        }
      ],
      "expo-updates"
    ],
    "experiments": {
      "typedRoutes": false
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "8c3d6d8e-f5e8-4945-90be-f4ad5311ca54"
      }
    },
    "owner": "victormnz",
    "updates": {
      "url": "https://u.expo.dev/8c3d6d8e-f5e8-4945-90be-f4ad5311ca54"
    }
  }
}
