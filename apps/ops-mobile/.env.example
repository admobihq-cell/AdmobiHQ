# Pulled from Infisical — do not commit real values.
# From repo root: npm run env:pull -w ops-mobile
# Staging: npm run env:pull:staging -w ops-mobile
#
# env:pull maps Infisical NEXT_PUBLIC_* keys to Expo EXPO_PUBLIC_* automatically.
# On a physical device, set API URL to your machine's LAN IP (not localhost).

EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=
EXPO_PUBLIC_API_URL=http://localhost:3003
