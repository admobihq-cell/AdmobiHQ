// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Lead {
  id                 Int     @id @default(autoincrement())
  email              String
  company_name       String
  phone              String?
  audience           String  // "campaign"
  budget_range       String? // "under_50k", "50k_150k", "150k_500k", "500k_plus", "not_sure"
  campaign_start_date DateTime?
  additional_info    String?
  created_at         DateTime @default(now())
  updated_at         DateTime @updatedAt

  @@map("leads")
}

model FleetPartner {
  id                   Int     @id @default(autoincrement())
  email                String
  company_name         String
  primary_contact_name String
  phone                String
  city                 String  // "Nairobi", "Mombasa", "Kisumu"
  fleet_types          String[]
  fleet_size           String?
  vehicles_active      String? // "yes", "no", "some"
  notes                String?
  status               String? @default("pending") // "pending", "verified", "active"
  created_at           DateTime @default(now())
  updated_at           DateTime @updatedAt

  @@map("fleet_partners")
}

model Driver {
  id              Int     @id @default(autoincrement())
  name            String
  phone           String
  email           String?
  city            String  // "Nairobi", "Mombasa", "Kisumu"
  vehicle_type    String? // "taxi", "delivery_bike", "three_wheeler", "other"
  days_per_week   String? // "1_2", "3_4", "5_6", "daily"
  heard_about     String? // "whatsapp", "facebook", "friend", "roadside", "other"
  status          String? @default("pending") // "pending", "verified", "active"
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  @@map("drivers")
}
