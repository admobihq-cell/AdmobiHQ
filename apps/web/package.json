{
  "name": "web",
  "version": "0.0.1",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "tsx scripts/fix-importmap.ts && next dev --webpack",
    "dev:turbo": "tsx scripts/fix-importmap.ts && next dev --turbopack",
    "generate:ai-seo": "tsx scripts/generate-ai-seo-static.ts",
    "prebuild": "npm run generate:ai-seo && tsx scripts/fix-importmap.ts",
    "build": "prisma generate && next build --webpack",
    "postbuild": "node scripts/run-sitemap.mjs",
    "start": "next start",
    "lint": "eslint",
    "format": "prettier --write \"**/*.{ts,tsx}\"",
    "typecheck": "tsc --noEmit && tsx scripts/verify-importmap.ts",
    "verify:importmap": "tsx scripts/verify-importmap.ts",
    "prisma": "prisma",
    "db:push": "dotenv -e .env.local -- prisma db push",
    "db:ops-schema": "dotenv -e .env.local -- prisma db execute --file prisma/scripts/ops-schema-additive.sql",
    "db:pull": "dotenv -e .env.local -- prisma db pull",
    "db:migrate": "dotenv -e .env.local -- prisma migrate dev",
    "payload": "dotenv -e .env.local -- cross-env NODE_OPTIONS=--no-deprecation payload",
    "generate:types": "npm run payload generate:types",
    "generate:importmap": "npm run payload generate:importmap && tsx scripts/fix-importmap.ts",
    "payload:migrate": "npm run payload migrate",
    "payload:migrate:create": "npm run payload migrate:create",
    "payload:migrate:ci": "cross-env NODE_OPTIONS=--no-deprecation payload migrate",
    "seed:blog:ci": "tsx scripts/seed-blog.ts",
    "seed:help:ci": "tsx scripts/seed-help.ts",
    "cms:bootstrap:ci": "npm run payload:migrate:ci && npm run seed:help:ci && npm run seed:blog:ci",
    "env:check": "dotenv -e .env.local -- tsx scripts/check-env.ts",
    "seed:help": "dotenv -e .env.local -- tsx scripts/seed-help.ts",
    "seed:blog": "dotenv -e .env.local -- tsx scripts/seed-blog.ts",
    "env:pull": "infisical export --env=dev --format=dotenv --output-file=.env.local",
    "env:pull:staging": "infisical export --env=staging --format=dotenv --output-file=.env.local"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@payload-bites/image-search": "^3.5.0",
    "@payloadcms/db-postgres": "^3.86.0",
    "@payloadcms/next": "^3.86.0",
    "@payloadcms/richtext-lexical": "^3.86.0",
    "@payloadcms/storage-vercel-blob": "^3.86.0",
    "@payloadcms/ui": "^3.85.0",
    "@prisma/adapter-pg": "^7.9.0",
    "@prisma/client": "^7.9.0",
    "@sentry/nextjs": "^10.68.0",
    "@vercel/analytics": "^2.0.1",
    "@vercel/functions": "^3.7.5",
    "@vercel/speed-insights": "^2.0.0",
    "@workspace/ops-api-client": "*",
    "@workspace/sentry-config": "^0.0.0",
    "@workspace/ui": "*",
    "bull": "^4.16.5",
    "dotenv": "^16.6.1",
    "graphql": "^16.14.0",
    "lucide-react": "^1.26.0",
    "next": "^16.2.11",
    "next-sitemap": "^4.2.3",
    "payload": "^3.86.0",
    "pg": "^8.22.0",
    "react": "^19.2.8",
    "react-dom": "^19.2.8",
    "react-email": "^6.9.1",
    "react-hook-form": "^7.82.0",
    "redis": "^6.1.0",
    "resend": "^6.18.0",
    "sharp": "^0.34.5",
    "zod": "3.25.76"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.3",
    "@types/node": "^25.1.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@workspace/eslint-config": "*",
    "@workspace/typescript-config": "*",
    "cross-env": "^7.0.3",
    "dotenv-cli": "^8.0.0",
    "eslint": "^9.39.5",
    "prisma": "^7.9.0",
    "tsx": "^4.23.1",
    "typescript": "^5.9.3"
  }
}
