# Pulled from Infisical — do not commit real values.
# From repo root: npm run env:pull -w api
# Staging: npm run env:pull:staging -w api

DATABASE_URL=
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Public API origin (no trailing slash). Clients use this at build/bundle time.
NEXT_PUBLIC_API_URL=http://localhost:3003

# Comma-separated origins allowed for cross-origin API calls (web, ops, app, Expo)
API_CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3002,http://localhost:8081,http://localhost:8082,http://localhost:19006,exp://localhost:8081,exp://localhost:8082

# Form submission emails (moved from web)
resend_api_key=
SENDER_EMAIL=Admobi <noreply@admobihq.com>
ADMIN_EMAIL=admobihq@gmail.com,victor@admobihq.com,japheth@admobihq.com
REDIS_URL=

# Sentry — admobi-media / admobi-hq
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
SENTRY_ORG=admobi-media
SENTRY_PROJECT=admobi-hq
