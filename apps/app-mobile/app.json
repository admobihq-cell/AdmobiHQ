{
  "expo": {
    "name": "Admobi",
    "slug": "admobihq-app",
    "version": "0.0.3",
    "orientation": "portrait",
    "runtimeVersion": "0.0.3",
    "icon": "./assets/images/icon.png",
    "scheme": "admobihq-app",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.admobihq.app",
      "infoPlist": {
        "UIBackgroundModes": ["remote-notification"]
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#FAF9F7",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "package": "com.admobihq.app",
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "POST_NOTIFICATIONS",
        "VIBRATE"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-dev-client",
      "expo-secure-store",
      "@maplibre/maplibre-react-native",
      "expo-web-browser",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "resizeMode": "contain",
          "backgroundColor": "#000000",
          "imageWidth": 200,
          "ios": {
            "backgroundColor": "#000000",
            "image": "./assets/images/splash-icon.png",
            "resizeMode": "contain"
          },
          "android": {
            "backgroundColor": "#000000",
            "image": "./assets/images/splash-icon.png",
            "resizeMode": "contain",
            "imageWidth": 200
          }
        }
      ],
      "expo-updates",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Allow Admobi to use your location to show nearby corridors on the map.",
          "locationAlwaysAndWhenInUsePermission": false,
          "locationAlwaysPermission": false,
          "isAndroidBackgroundLocationEnabled": false,
          "isIosBackgroundLocationEnabled": false
        }
      ],
      [
        "expo-notifications",
        {
          "color": "#0B6E4F",
          "defaultChannel": "default"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Admobi to access photos for campaign creatives.",
          "cameraPermission": "Allow Admobi to take photos for campaign creatives."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": false
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "17e31060-6e4d-4b1a-8e85-37464fd2b159"
      }
    },
    "owner": "victormnz",
    "updates": {
      "url": "https://u.expo.dev/17e31060-6e4d-4b1a-8e85-37464fd2b159"
    }
  }
}
