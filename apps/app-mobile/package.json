{
  "name": "app-mobile",
  "main": "expo-router/entry",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "expo start --port 8082 --offline",
    "dev:clear": "expo start --port 8082 --offline --clear",
    "start": "expo start --port 8082 --offline",
    "start:clear": "expo start --port 8082 --offline --clear",
    "android": "expo start --port 8082 --android --offline",
    "run:android": "expo run:android --port 8082",
    "ios": "expo start --port 8082 --ios --offline",
    "web": "expo start --port 8082 --web --offline",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "env:pull": "node ./scripts/pull-env.mjs dev",
    "env:pull:staging": "node ./scripts/pull-env.mjs staging",
    "env:check": "node ./scripts/check-env.mjs",
    "assets:sync": "node ../../scripts/sync-mobile-brand-assets.mjs",
    "prebuild:android": "expo prebuild --platform android --clean",
    "build:android:preview": "eas build --platform android --profile preview --non-interactive",
    "build:android:production": "eas build --platform android --profile production --non-interactive",
    "update:preview": "eas update --channel preview --non-interactive",
    "update:production": "eas update --channel production --non-interactive"
  },
  "dependencies": {
    "@maplibre/maplibre-react-native": "^10.4.2",
    "@workspace/geo": "*",
    "expo": "~54.0.35",
    "expo-constants": "~18.0.13",
    "expo-dev-client": "~6.0.20",
    "expo-font": "~14.0.11",
    "expo-linking": "~8.0.11",
    "expo-router": "~6.0.23",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "expo-updates": "~29.0.16",
    "metro": "^0.83.1",
    "metro-config": "^0.83.3",
    "metro-runtime": "^0.83.3",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "^15.15.5",
    "react-native-web": "~0.21.0",
    "react-native-webview": "13.15.0",
    "react-native-worklets": "0.5.1"
  },
  "devDependencies": {
    "@types/react": "~19.1.10",
    "@workspace/eslint-config": "*",
    "@workspace/typescript-config": "*",
    "eslint": "^9.39.2",
    "typescript": "~5.9.2"
  }
}
